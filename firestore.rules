rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' || 
         (request.auth.token.email == "anand@one.mn" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'teacher';
    }

    function teacherOwnsClass(classId) {
      return classId is string &&
        exists(/databases/$(database)/documents/classes/$(classId)) &&
        (
          get(/databases/$(database)/documents/classes/$(classId)).data.teacherId == request.auth.uid ||
          (
            get(/databases/$(database)/documents/classes/$(classId)).data.teacher is string &&
            get(/databases/$(database)/documents/users/$(request.auth.uid)).data.displayName is string &&
            get(/databases/$(database)/documents/classes/$(classId)).data.teacher ==
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.displayName
          )
        );
    }

    function teacherCanAccessBooking(bookingData) {
      return isTeacher() &&
        bookingData.type == 'class' &&
        (
          (bookingData.classId is string && teacherOwnsClass(bookingData.classId)) ||
          (bookingData.itemId is string && teacherOwnsClass(bookingData.itemId)) ||
          (
            bookingData.scheduleId is string &&
            exists(/databases/$(database)/documents/schedule/$(bookingData.scheduleId)) &&
            teacherOwnsClass(get(/databases/$(database)/documents/schedule/$(bookingData.scheduleId)).data.classId)
          )
        );
    }

    function bookingScheduleExists(bookingData) {
      return bookingData.scheduleId is string &&
        exists(/databases/$(database)/documents/schedule/$(bookingData.scheduleId));
    }

    function bookingStartTime(bookingData) {
      return bookingData.classStartTime is timestamp
        ? bookingData.classStartTime
        : get(/databases/$(database)/documents/schedule/$(bookingData.scheduleId)).data.startAt;
    }

    function bookingTimeDataAvailable(bookingData) {
      return (bookingData.classStartTime is timestamp) ||
        (
          bookingScheduleExists(bookingData) &&
          get(/databases/$(database)/documents/schedule/$(bookingData.scheduleId)).data.startAt is timestamp
        );
    }

    function isBookingEditableNow(bookingData) {
      return bookingTimeDataAvailable(bookingData) &&
        request.time >= bookingStartTime(bookingData) &&
        request.time <= bookingStartTime(bookingData) + duration.value(24, 'h');
    }

    function teacherCanReadBookingNow(bookingData) {
      return teacherCanAccessBooking(bookingData) &&
        (
          !bookingTimeDataAvailable(bookingData) ||
          request.time <= bookingStartTime(bookingData) + duration.value(24, 'h')
        );
    }

    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string && 
             request.resource.data[field].size() >= minLen && 
             request.resource.data[field].size() <= maxLen;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Publicly readable collections, Admin writable
    match /blog/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /classes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /retreats/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /teachers/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /gallery/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /onlineContent/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /mindfulness/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Site-level content (home hero, etc.)
    match /siteContent/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /schedule/{id} {
      allow read: if true;
      allow write: if isAdmin() || (
        isAuthenticated() &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['bookedCount']) &&
        request.resource.data.bookedCount is int &&
        resource.data.bookedCount is int &&
        request.resource.data.bookedCount == resource.data.bookedCount + 1 &&
        request.resource.data.bookedCount <= resource.data.capacity
      );
    }

    // Media library (admin CRUD + picker in admin UI)
    match /media/{id} {
      allow read, write: if isAdmin();
    }

    // User profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();
    }

    // Bookings
    match /bookings/{id} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isAdmin() ||
        teacherCanReadBookingNow(resource.data)
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (
        teacherCanAccessBooking(resource.data) &&
        isBookingEditableNow(resource.data) &&
        request.resource.data.diff(resource.data).changedKeys().hasOnly(['attendanceStatus', 'attendanceMarkedAt']) &&
        request.resource.data.attendanceStatus is string &&
        request.resource.data.attendanceStatus in ['attended', 'missed', 'unknown', 'present', 'absent'] &&
        request.resource.data.attendanceMarkedAt is timestamp
      );
      allow delete: if isAdmin();
    }
  }
}
